# PenguinLab ARM64 QEMU virt 学习配置
# ─────────────────────────────────────
# 基于 allnoconfig，只开启内核学习所需的最小功能集
#
# 设计原则：
#   - 能在 QEMU virt 机器上启动进入 BusyBox shell
#   - 支持内核模块加载和卸载
#   - 支持 GDB 远程调试
#   - 不包含任何真实 SoC/物理硬件驱动
#
# 使用方法：
#   cd third_party/linux
#   make O=../../out/build_latest_arm64 allnoconfig
#   scripts/kconfig/merge_config.sh -m O=../../out/build_latest_arm64/.config ../../configs/arm64-qemu-virt-learn.config
#   make O=../../out/build_latest_arm64 olddefconfig
#   make O=../../out/build_latest_arm64 -j$(nproc) Image
#
# 或者用项目脚本（需先 config 再 build）：
#   cd third_party/linux
#   make O=../../out/build_latest_arm64 allnoconfig
#   scripts/kconfig/merge_config.sh -m ../../out/build_latest_arm64/.config ../../configs/arm64-qemu-virt-learn.config
#   cd ../..
#   ARCH=aarch64 ./scripts/linux-action-scripts.sh build

# === 平台基础 ===
CONFIG_ARM64=y
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=2

# === 串口控制台 (QEMU virt 的 PL011 UART) ===
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_CONSOLE_TRANSLATIONS=y

# === initramfs (加载 BusyBox rootfs) ===
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# === 基础文件系统 ===
# devtmpfs: 内核自动填充 /dev 设备节点，BusyBox 的 mknod 才能工作
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
# procfs: ps、top、cat /proc/* 等都需要
CONFIG_PROC_FS=y
# sysfs: ls /sys/*、设备模型浏览
CONFIG_SYSFS=y
# tmpfs: BusyBox init 脚本用 mount -t tmpfs 挂载 /dev
CONFIG_TMPFS=y

# === 内核模块 ===
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y

# === 调试支持 (GDB + 学习必备) ===
# debugfs: 很多内核调试接口挂载在这里
CONFIG_DEBUG_FS=y
# 调试信息：GDB 断点、变量查看、堆栈回溯都需要
CONFIG_DEBUG_INFO=y
# GDB python 辅助脚本：lx-symbols、lx-ps 等便捷命令
CONFIG_GDB_SCRIPTS=y
# printk：内核日志输出，没有它等于瞎了
CONFIG_PRINTK=y
# BUG() 宏：内核断言失败时产生 oops
CONFIG_BUG=y
# kallsyms：/proc/kallsyms 里能看到所有内核符号地址
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# === VirtIO (QEMU virt 机器的核心设备总线) ===
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y

# === BusyBox 运行所需的二进制格式 ===
# ELF：BusyBox 本体是 ELF 可执行文件
CONFIG_BINFMT_ELF=y
# script：/init 是 #!/bin/sh 开头的脚本
CONFIG_BINFMT_SCRIPT=y

# === POSIX 接口 (BusyBox shell 和基本命令需要) ===
CONFIG_MULTIUSER=y
CONFIG_SYSVIPC=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_SHMEM=y

# === 高精度定时器 (让 sleep 等命令精度正常) ===
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ_IDLE=y

# === 调试与追踪 (为 debugging 藤亲测启用 · 第一批: kprobes/ftrace/dynamic-debug/锁检测)===
# kprobes: 动态插桩, 探测任意指令/函数入口 (debug-kprobes 节点)
CONFIG_KPROBES=y
CONFIG_KRETPROBES=y
CONFIG_KPROBE_EVENTS=y
# ftrace: 函数追踪 / 事件追踪 (debug-ftrace 节点)
CONFIG_TRACING=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_EVENT_TRACING=y
# dynamic-debug / atomic-sleep 检测: 暂不开 ——
# 这俩 config 会让 uaccess / pr_debug 内联进对 __might_fault / __dynamic_pr_debug
# 的引用, 而 build 后 Module.symvers 没收集这俩符号, 外部模块 modpost 失败。
# pr_debug 改用编译期 -DDEBUG 开(见 example/mini/06-debug-printk 的 Makefile)。
# CONFIG_DYNAMIC_DEBUG=y
# CONFIG_DEBUG_ATOMIC_SLEEP=y
# 锁依赖检测: 死锁排查 (debug-lockdep 节点)
CONFIG_LOCKDEP=y
